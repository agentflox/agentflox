{
  "name": "service-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,worker -c green,cyan \"tsx watch src/main.api.ts\" \"tsx watch src/main.worker.ts\"",
    "dev:api": "tsx watch src/main.api.ts",
    "dev:worker": "tsx watch src/main.worker.ts",
    "prebuild": "pnpm --filter @agentflox/types build && pnpm --filter @agentflox/logger build && pnpm --filter @agentflox/config build && pnpm --filter @agentflox/errors build",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/main.api.js",
    "start:api": "node dist/main.api.js",
    "start:worker": "node dist/main.worker.js",
    "start:all": "concurrently -k -n api,worker \"node dist/main.api.js\" \"node dist/main.worker.js\"",
    "postbuild": "node scripts/fix-esm-imports.cjs",
    "clean": "rm -rf dist node_modules",
    "pretype-check": "pnpm --filter @agentflox/types build",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/generative-ai": "^0.24.1",
    "@langchain/langgraph": "^0.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-jaeger": "^1.30.1",
    "@opentelemetry/instrumentation": "^0.52.1",
    "@opentelemetry/instrumentation-express": "^0.41.1",
    "@opentelemetry/instrumentation-http": "^0.52.1",
    "@opentelemetry/instrumentation-ioredis": "^0.42.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@paypal/paypal-server-sdk": "^1.1.0",
    "@prisma/instrumentation": "^5.22.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "@supabase/supabase-js": "^2.39.0",
    "@types/node": "^20.10.6",
    "@types/uuid": "^11.0.0",
    "@types/winston": "^2.4.4",
    "@agentflox/config": "workspace:*",
    "@agentflox/database": "workspace:*",
    "@agentflox/errors": "workspace:*",
    "@agentflox/logger": "workspace:*",
    "@agentflox/types": "workspace:*",
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "bullmq": "^5.63.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "inngest": "^3.48.0",
    "ioredis": "^5.8.2",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.0",
    "lru-cache": "^11.2.4",
    "luxon": "^3.7.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "opossum": "^9.0.0",
    "pg": "^8.11.3",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^9.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.6.1",
    "stripe": "^19.1.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "yjs": "^13.6.29",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.10.9",
    "concurrently": "^8.2.2",
    "socket.io-client": "^4.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}