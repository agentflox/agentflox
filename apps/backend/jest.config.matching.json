{
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
        "<rootDir>/__tests__"
    ],
    "testMatch": [
        "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
        "src/services/matching/**/*.ts",
        "!src/services/matching/**/*.d.ts",
        "!src/services/matching/**/index.ts"
    ],
    "coverageThresholds": {
        "global": {
            "branches": 70,
            "functions": 75,
            "lines": 80,
            "statements": 80
        }
    },
    "setupFilesAfterEnv": [
        "<rootDir>/__tests__/setup.ts"
    ]
}