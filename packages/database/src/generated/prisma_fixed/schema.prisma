  @@index([workspaceId])
  @@index([spaceId])
  @@index([parentId])
  @@index([status])
  @@index([category])
  @@index([type])
  @@index([slug])
  @@index([isFeatured])
  @@index([isPremium])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([tags])
  @@index([title])
  @@index([description])
  @@map("resources")
}

