generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma_fixed"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                             String                     @id @default(cuid())
  email                          String                     @unique
  emailVerified                  DateTime?                  @map("email_verified")
  name                           String?
  image                          String?
  password                       String?
  firstName                      String?                    @map("first_name")
  lastName                       String?                    @map("last_name")
  username                       String?                    @unique
  avatar                         String?
  bio                            String?
  phone                          String?
  website                        String?
  location                       String?
  timezone                       String?                    @default("UTC")
  userType                       UserType                   @default(FOUNDER) @map("user_type")
  isActive                       Boolean                    @default(true) @map("is_active")
  isVerified                     Boolean                    @default(false) @map("is_verified")
  onboardingCompleted            Boolean                    @default(false) @map("onboarding_completed")
  onboardingStep                 Int                        @default(0) @map("onboarding_step")
  role                           String?
  usagePurpose                   String?                    @map("usage_purpose")
  managementGoals                String[]                   @map("management_goals")
  referralSource                 String?                    @map("referral_source")
  credibilityScore               Float                      @default(0) @map("credibility_score")
  verificationLevel              VerificationLevel          @default(UNVERIFIED) @map("verification_level")
  isKycVerified                  Boolean                    @default(false) @map("is_kyc_verified")
  kycDocuments                   String[]                   @map("kyc_documents")
  createdAt                      DateTime                   @default(now()) @map("created_at")
  updatedAt                      DateTime                   @updatedAt @map("updated_at")
  lastActiveAt                   DateTime?                  @map("last_active_at")
  embedding                      Unsupported("vector")?
  embeddingUpdatedAt             DateTime?                  @map("embedding_updated_at")
  accounts                       Account[]
  activityLogs                   ActivityLog[]
  agentAuditLogs                 AgentAuditLog[]
  agentCollaborators             AgentCollaborator[]
  agentFeedback                  AgentFeedback[]
  agentTemplates                 AgentTemplate[]
  aiAgents                       AiAgent[]
  aiConversationFeedback         AiConversationFeedback[]
  sharedConversations            AiConversationShare[]      @relation("SharedBy")
  receivedConversations          AiConversationShare[]      @relation("SharedWith")
  aiConversations                AiConversation[]
  messageAnnotations             AiMessageAnnotation[]
  aiMessageFeedback              AiMessageFeedback[]
  aiUsageLogs                    AiUsageLog[]
  automationsCreated             Automation[]
  channelMemberships             ChannelMember[]
  channelMessages                ChannelMessage[]
  channelsCreated                Channel[]
  checklistAssignments           ChecklistItem[]
  compositeTools                 CompositeTool[]
  receivedConnections            Connection[]               @relation("ConnectionReceiver")
  connections                    Connection[]               @relation("ConnectionRequester")
  creditPurchases                CreditPurchase[]           @relation("userCreditPurchases")
  customRolesCreated             CustomRole[]               @relation("CustomRoleCreator")
  dashboardsCreated              Dashboard[]
  discounts                      DiscountToUser[]           @relation("userDiscounts")
  documentCollaborations         DocumentCollaborator[]
  documentVersions               DocumentVersion[]
  documentsCreated               Document[]
  founderProfile                 FounderProfile?
  goalUpdates                    GoalUpdate[]
  goalsOwned                     Goal[]
  investments                    Investment[]
  investorProfile                InvestorProfile?
  receivedInvitations            Invitation[]               @relation("InvitationReceiver")
  sentInvitations                Invitation[]               @relation("InvitationSender")
  permissionsGranted             LocationPermission[]       @relation("PermissionGranter")
  locationPermissions            LocationPermission[]       @relation("UserLocationPermissions")
  marketplaceOrders              MarketplaceOrder[]
  materialPurchases              MaterialPurchase[]         @relation("MaterialPurchasesBuyer")
  ownedMaterials                 Material[]                 @relation("MaterialOwner")
  memberProfile                  MemberProfile?
  receivedMessages               Message[]                  @relation("MessageReceiver")
  sentMessages                   Message[]                  @relation("MessageSender")
  notifications                  Notification[]
  organizationMemberships        OrganizationMember[]
  ownedOrganizations             Organization[]             @relation("OrganizationOwner")
  payments                       Payment[]                  @relation("userPayments")
  payouts                        Payout[]                   @relation("UserPayouts")
  cancelledPermissionInvitations PermissionInvitation[]     @relation("InvitationCanceller")
  sentPermissionInvitations      PermissionInvitation[]     @relation("InvitationSender")
  receivedPermissionInvitations  PermissionInvitation[]     @relation("InvitationRecipient")
  postCommentVotes               PostCommentVote[]
  postComments                   PostComment[]
  postLikes                      PostLike[]
  postShares                     PostShare[]
  posts                          Post[]
  blockedUsers                   ProjectBlockedMember[]     @relation("BlockerUser")
  blockedFromProjects            ProjectBlockedMember[]     @relation("BlockedUser")
  projectComments                ProjectComment[]
  projectLikes                   ProjectLike[]
  participatedProjects           ProjectMember[]
  transfersFrom                  ProjectOwnershipTransfer[] @relation("TransferFrom")
  transfersTo                    ProjectOwnershipTransfer[] @relation("TransferTo")
  ownedProjects                  Project[]                  @relation("ProjectOwner")
  promotions                     PromotionToUser[]          @relation("userPromotions")
  proposalComments               ProposalComment[]
  proposalLikes                  ProposalLike[]
  proposals                      Proposal[]
  publicLinksCreated             PublicLink[]               @relation("PublicLinkCreator")
  receivedRequests               Request[]                  @relation("RequestReceiver")
  sentRequests                   Request[]                  @relation("RequestSender")
  resourceBookmarks              ResourceBookmark[]
  resourceComments               ResourceComment[]
  resourcePermissions            ResourcePermission[]
  resourceRatings                ResourceRating[]
  resourceShares                 ResourceShare[]
  resourceVersions               ResourceVersion[]
  ownedResources                 Resource[]                 @relation("ResourceOwner")
  givenReviews                   Review[]                   @relation("ReviewGiver")
  receivedReviews                Review[]                   @relation("ReviewReceiver")
  sessions                       Session[]
  skillEndorsements              SkillEndorsement[]         @relation("SkillEndorser")
  spaceMemberships               SpaceMember[]
  subscriptions                  Subscription[]             @relation("userSubscriptions")
  taskActivities                 TaskActivity[]
  taskAssignees                  TaskAssignee[]             @relation("TaskAssigneesUser")
  taskAttachments                TaskAttachment[]
  taskComments                   TaskComment[]
  taskPermissionsGranted         TaskPermission[]           @relation("TaskPermissionGranter")
  taskPermissions                TaskPermission[]           @relation("UserTaskPermissions")
  taskWatchers                   TaskWatcher[]
  tasksCreated                   Task[]                     @relation("TaskCreator")
  teamComments                   TeamComment[]
  teamLikes                      TeamLike[]
  teamMemberships                TeamMember[]               @relation("TeamMemberUser")
  ownedTeams                     Team[]                     @relation("TeamOwner")
  templatesCreated               Template[]
  timeEntries                    TimeEntry[]
  ownedTools                     Tool[]                     @relation("ToolOwner")
  usages                         Usage[]                    @relation("userUsages")
  activities                     UserActivity[]
  commentsReceived               UserComment[]              @relation("UserCommentsReceived")
  commentsGiven                  UserComment[]              @relation("UserCommentsGiven")
  interests                      UserInterest[]
  likesReceived                  UserLike[]                 @relation("UserLikesReceived")
  likesGiven                     UserLike[]                 @relation("UserLikesGiven")
  quota                          UserQuota?
  settings                       UserSettings?
  skills                         UserSkill[]
  vectorEmbeddings               VectorEmbedding[]
  verificationRequests           VerificationRequest[]
  viewShares                     ViewShare[]
  viewsCreated                   View[]
  webhooksCreated                Webhook[]
  workspaceActivities            WorkspaceActivity[]
  invitedGuests                  WorkspaceGuest[]           @relation("GuestInviter")
  guestMemberships               WorkspaceGuest[]           @relation("UserGuestWorkspaces")
  workspaceMemberships           WorkspaceMember[]          @relation("WorkspaceMemberUser")
  ownedWorkspaces                Workspace[]                @relation("WorkspaceOwner")

  workforces Workforce[]

  @@map("users")
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  ownerId     String               @map("owner_id")
  logo        String?
  domain      String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  description String?
  website     String?
  socialLinks Json?
  aiAgents    AiAgent[]
  departments Department[]
  members     OrganizationMember[]
  owner       User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  projects    Project[]
  teams       Team[]
  workspaces  Workspace[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  role           String       @default("MEMBER")
  joinedAt       DateTime     @default(now()) @map("joined_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Department {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  description    String?
  headId         String?      @map("head_id")
  color          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  aiAgents       AiAgent[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
  teams          Team[]

  @@map("departments")
}

model Workspace {
  id                    String                 @id @default(cuid())
  ownerId               String                 @map("owner_id")
  name                  String
  description           String?
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  archivedAt            DateTime?              @map("archived_at")
  avatar                String?
  color                 String?                @default("#3B82F6")
  organizationId        String?                @map("organization_id")
  embedding             Unsupported("vector")?
  embeddingUpdatedAt    DateTime?              @map("embedding_updated_at")
  isArchived            Boolean                @default(false) @map("is_archived")
  memberLimit           Int?                   @map("member_limit")
  settings              Json?
  slug                  String?                @unique
  storageLimit          BigInt?                @map("storage_limit")
  storageUsed           BigInt                 @default(0) @map("storage_used")
  agentTemplates        AgentTemplate[]
  aiAgents              AiAgent[]
  agentWorkflows        AgentWorkflow[]
  aiConversations       AiConversation[]       @relation("WorkspaceConversations")
  automations           Automation[]
  channels              Channel[]
  compositeTools        CompositeTool[]
  customFields          CustomField[]
  customRoles           CustomRole[]           @relation("WorkspaceCustomRoles")
  dashboards            Dashboard[]
  documents             Document[]
  folders               Folder[]
  goals                 Goal[]
  integrations          Integration[]
  lists                 List[]
  materials             Material[]
  permissionInvitations PermissionInvitation[] @relation("WorkspaceInvitations")
  projects              Project[]
  proposals             Proposal[]
  publicLinks           PublicLink[]           @relation("WorkspacePublicLinks")
  resources             Resource[]
  spaces                Space[]
  taskStatuses          TaskStatus[]
  taskTypes             TaskType[]
  tasks                 Task[]
  teams                 Team[]
  templates             Template[]
  tools                 Tool[]
  webhooks              Webhook[]
  activityLogs          WorkspaceActivity[]
  analytics             WorkspaceAnalytics[]
  permissionGuests      WorkspaceGuest[]       @relation("WorkspaceGuests")
  invitations           WorkspaceInvitation[]
  members               WorkspaceMember[]
  organization          Organization?          @relation(fields: [organizationId], references: [id])
  owner                 User                   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workforces            Workforce[]

  @@index([ownerId])
  @@index([organizationId])
  @@index([slug])
  @@index([isActive, isArchived])
  @@index([createdAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id                   String              @id @default(cuid())
  workspaceId          String              @map("workspace_id")
  userId               String              @map("user_id")
  canCreateSpaces      Boolean             @default(false) @map("can_create_spaces")
  canInvite            Boolean             @default(false) @map("can_invite")
  canManageBilling     Boolean             @default(false) @map("can_manage_billing")
  customization        Json?
  invitedBy            String?             @map("invited_by")
  joinedAt             DateTime            @default(now()) @map("joined_at")
  lastActiveAt         DateTime?           @map("last_active_at")
  leftAt               DateTime?           @map("left_at")
  notificationSettings Json?               @map("notification_settings")
  permissions          Json?
  status               MemberStatus        @default(ACTIVE)
  role                 WorkspaceRole       @default(MEMBER)
  customRoleId         String?             @map("custom_role_id")
  activities           WorkspaceActivity[]
  customRole           CustomRole?         @relation("MemberCustomRole", fields: [customRoleId], references: [id])
  user                 User                @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([status])
  @@index([role])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  invitedBy   String        @map("invited_by")
  email       String
  role        WorkspaceRole @default(MEMBER)
  token       String        @unique
  expiresAt   DateTime      @map("expires_at")
  acceptedAt  DateTime?     @map("accepted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model Space {
  id                 String                 @id @default(cuid())
  workspaceId        String                 @map("workspace_id")
  name               String
  description        String?
  isActive           Boolean                @default(true) @map("is_active")
  createdBy          String                 @map("created_by")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  embedding          Unsupported("vector")?
  embeddingUpdatedAt DateTime?              @map("embedding_updated_at")
  icon               String?
  color              String?
  visibility         Visibility             @default(OWNERS_ADMINS)
  settings           Json?
  aiAgents           AiAgent[]
  aiConversations    AiConversation[]       @relation("SpaceConversations")
  automations        Automation[]
  compositeTools     CompositeTool[]
  customFields       CustomField[]
  folders            Folder[]
  lists              List[]
  materials          Material[]
  projects           Project[]
  proposals          Proposal[]
  resources          Resource[]
  members            SpaceMember[]
  workspace          Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskStatuses       TaskStatus[]
  taskTypes          TaskType[]
  tasks              Task[]
  teams              Team[]
  tools              Tool[]
  views              View[]

  @@index([workspaceId])
  @@index([isActive])
  @@map("spaces")
}

model Integration {
  id          String              @id @default(cuid())
  workspaceId String?             @map("workspace_id")
  provider    IntegrationProvider
  config      Json
  credentials String?             @map("encrypted_credentials")
  isActive    Boolean             @default(true) @map("is_active")
  installedBy String              @map("installed_by")
  installedAt DateTime            @default(now()) @map("installed_at")
  lastSyncAt  DateTime?           @map("last_sync_at")
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([provider])
  @@map("integrations")
}

model AutomationLog {
  id              String           @id @default(cuid())
  automationId    String           @map("automation_id")
  status          AutomationStatus
  triggerData     Json             @map("trigger_data")
  actionsExecuted Json             @map("actions_executed")
  error           String?
  executedAt      DateTime         @default(now()) @map("executed_at")
  automation      Automation       @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([executedAt])
  @@map("automation_logs")
}

model Task {
  id                  String             @id @default(cuid())
  workspaceId         String?            @map("workspace_id")
  channelId           String?            @map("channel_id")
  projectId           String?            @map("project_id")
  teamId              String?            @map("team_id")
  title               String
  description         String?
  assigneeId          String?            @map("assignee_id")
  createdBy           String             @map("created_by")
  visibility          Visibility         @default(OWNERS_ADMINS)
  isPublic            Boolean            @default(false) @map("is_public")
  proposalId          String?            @unique @map("proposal_id")
  priority            TaskPriority       @default(NORMAL)
  taskTypeId          String?            @map("task_type_id")
  startDate           DateTime?          @map("start_date")
  dueDate             DateTime?          @map("due_date")
  timeEstimate        Int?               @map("time_estimate")
  isStarred           Boolean            @default(false) @map("is_starred")
  tags                String[]           @default([])
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  position            String             @default("a0")
  listId              String?            @map("list_id")
  statusId            String?            @map("status_id")
  spaceId             String?            @map("space_id")
  parentId            String?            @map("parent_id")
  order               String             @default("a0")
  aiConversations     AiConversation[]
  checklists          Checklist[]
  customFieldValues   CustomFieldValue[]
  activities          TaskActivity[]
  assignees           TaskAssignee[]     @relation("TaskAssignees")
  attachments         TaskAttachment[]
  comments            TaskComment[]
  blockedDependencies TaskDependency[]   @relation("BlockingTask")
  dependencies        TaskDependency[]   @relation("DependentTask")
  taskPermissions     TaskPermission[]   @relation("TaskPermissions")
  watchers            TaskWatcher[]
  channel             Channel?           @relation(fields: [channelId], references: [id])
  creator             User               @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  list                List?              @relation(fields: [listId], references: [id])
  tasks               Task?              @relation("tasksTotasks", fields: [parentId], references: [id], onDelete: Cascade)
  other_tasks         Task[]             @relation("tasksTotasks")
  project             Project?           @relation(fields: [projectId], references: [id])
  proposal            Proposal?          @relation(fields: [proposalId], references: [id])
  space               Space?             @relation(fields: [spaceId], references: [id])
  status              TaskStatus?        @relation(fields: [statusId], references: [id])
  taskType            TaskType?          @relation(fields: [taskTypeId], references: [id])
  team                Team?              @relation(fields: [teamId], references: [id])
  workspace           Workspace?         @relation(fields: [workspaceId], references: [id])
  timeEntries         TimeEntry[]

  @@index([workspaceId])
  @@index([listId])
  @@index([statusId])
  @@index([channelId])
  @@index([projectId])
  @@index([teamId])
  @@index([createdBy])
  @@index([assigneeId])
  @@index([parentId])
  @@index([parentId, order])
  @@map("tasks")
}

model TaskType {
  id          String     @id @default(cuid())
  workspaceId String?    @map("workspace_id")
  spaceId     String?    @map("space_id")
  projectId   String?    @map("project_id")
  teamId      String?    @map("team_id")
  folderId    String?    @map("folder_id")
  listId      String?    @map("list_id")
  name        String
  description String?
  icon        String?
  color       String?
  isDefault   Boolean    @default(false) @map("is_default")
  isActive    Boolean    @default(true) @map("is_active")
  position    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  folder      Folder?    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  list        List?      @relation(fields: [listId], references: [id], onDelete: Cascade)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  space       Space?     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  team        Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([spaceId])
  @@index([projectId])
  @@index([teamId])
  @@map("task_types")
}

model TaskStatus {
  id          String     @id @default(cuid())
  listId      String     @map("list_id")
  workspaceId String?    @map("workspace_id")
  spaceId     String?    @map("space_id")
  projectId   String?    @map("project_id")
  teamId      String?    @map("team_id")
  folderId    String?    @map("folder_id")
  name        String
  color       String     @default("#94A3B8")
  position    Int        @default(0)
  type        StatusType @default(CUSTOM)
  createdAt   DateTime   @default(now()) @map("created_at")
  folder      Folder?    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  list        List       @relation(fields: [listId], references: [id], onDelete: Cascade)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  space       Space?     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  team        Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@index([listId])
  @@index([folderId])
  @@index([workspaceId])
  @@index([spaceId])
  @@index([projectId])
  @@index([teamId])
  @@map("task_statuses")
}

model TaskDependency {
  id          String         @id @default(cuid())
  taskId      String         @map("task_id")
  dependsOnId String         @map("depends_on_id")
  type        DependencyType @default(FINISH_TO_START)
  createdAt   DateTime       @default(now()) @map("created_at")
  dependsOn   Task           @relation("BlockingTask", fields: [dependsOnId], references: [id], onDelete: Cascade)
  task        Task           @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

model TaskAssignee {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  userId      String?  @map("user_id")
  teamId      String?  @map("team_id")
  agentId     String?  @map("agent_id") @db.Uuid
  assigned_at DateTime @default(now())
  assigned_by String?
  aiAgent     AiAgent? @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task        Task     @relation("TaskAssignees", fields: [taskId], references: [id], onDelete: Cascade)
  team        Team?    @relation("TaskAssigneesTeam", fields: [teamId], references: [id], onDelete: Cascade)
  user        User?    @relation("TaskAssigneesUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@unique([taskId, agentId])
  @@unique([taskId, teamId])
  @@index([userId])
  @@index([taskId])
  @@index([agentId])
  @@index([teamId])
  @@map("task_assignees")
}

model TaskWatcher {
  id      String   @id @default(cuid())
  taskId  String   @map("task_id")
  userId  String   @map("user_id")
  addedAt DateTime @default(now()) @map("added_at")
  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_watchers")
}

model TaskComment {
  id        String        @id @default(cuid())
  taskId    String        @map("task_id")
  userId    String        @map("user_id")
  parentId  String?       @map("parent_id")
  content   String
  isEdited  Boolean       @default(false) @map("is_edited")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  parent    TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   TaskComment[] @relation("CommentReplies")
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
