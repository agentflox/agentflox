  updatedAt   DateTime        @updatedAt @map("updated_at")
  grantedBy   User            @relation("TaskPermissionGranter", fields: [grantedById], references: [id], onDelete: Cascade)
  task        Task            @relation("TaskPermissions", fields: [taskId], references: [id], onDelete: Cascade)
  team        Team?           @relation("TeamTaskPermissions", fields: [teamId], references: [id], onDelete: Cascade)
  user        User?           @relation("UserTaskPermissions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@unique([taskId, teamId])
  @@index([taskId])
  @@index([userId])
  @@index([teamId])
  @@map("task_permissions")
}

model CustomRole {
  id          String            @id @default(cuid())
  workspaceId String            @map("workspace_id")
  name        String
  baseRole    WorkspaceRole     @map("base_role")
  permissions Json
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  createdBy   User              @relation("CustomRoleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  workspace   Workspace         @relation("WorkspaceCustomRoles", fields: [workspaceId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[] @relation("MemberCustomRole")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([baseRole])
  @@map("custom_roles")
}

model PermissionInvitation {
  id            String           @id @default(cuid())
  workspaceId   String?          @map("workspace_id")
  invitedById   String           @map("invited_by_id")
  email         String
  invitedUserId String?          @map("invited_user_id")
  inviteType    String           @map("invite_type")
  role          WorkspaceRole?
  targetType    String?          @map("target_type")
  targetId      String?          @map("target_id")
  permission    PermissionLevel?
  token         String           @unique
  expiresAt     DateTime         @map("expires_at")
  status        String           @default("pending")
  acceptedAt    DateTime?        @map("accepted_at")
  cancelledById String?          @map("cancelled_by_id")
  cancelledAt   DateTime?        @map("cancelled_at")
  metadata      Json?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  cancelledBy   User?            @relation("InvitationCanceller", fields: [cancelledById], references: [id])
  invitedBy     User             @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser   User?            @relation("InvitationRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  workspace     Workspace?       @relation("WorkspaceInvitations", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([invitedById])
  @@index([invitedUserId])
  @@index([email])
  @@index([status])
  @@index([token])
  @@index([expiresAt])
  @@map("permission_invitations")
}

model PublicLink {
  id           String          @id @default(cuid())
  workspaceId  String          @map("workspace_id")
  locationType String          @map("location_type")
  locationId   String          @map("location_id")
  token        String          @unique
  permission   PermissionLevel
  createdById  String          @map("created_by_id")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  expiresAt    DateTime?       @map("expires_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  createdBy    User            @relation("PublicLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation("WorkspacePublicLinks", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([locationType, locationId])
  @@index([workspaceId])
  @@index([token])
  @@index([isActive])
  @@map("public_links")
}

model AgentRunEvent {
  id            String   @id @default(uuid())
  runId         String   @map("run_id")
  tenantId      String   @map("tenant_id")
  schemaVersion String   @default("1") @map("schema_version")
  eventType     String   @map("event_type")
  fsmState      String?  @map("fsm_state")
  stepId        String?  @map("step_id")
  tool          String?
  status        String
  costUsd       Float?   @map("cost_usd")
  tokens        Int?
  payload       Json?
  timestamp     DateTime @default(now())

  @@index([runId])
  @@index([tenantId])
  @@index([runId, timestamp])
  @@index([eventType])
  @@index([fsmState])
  @@map("agent_run_events")
}

